# Sanity CMS — proyecto y dataset (públicos, requeridos)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token — solo lectura, NUNCA con prefijo NEXT_PUBLIC_
SANITY_API_TOKEN=your_read_token

# SMTP — para envío de formulario de contacto
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_password
SMTP_FROM=Allura Healthcare <your@email.com>
